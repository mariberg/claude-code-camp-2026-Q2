+```jsonc
+// Any MCP client's server config — e.g. .mcp.json, claude_desktop_config.json
+{
+  "mcpServers": {
+    "mud": {
+      "command": "mud-manager",
+      "args": ["--mcp"],
+      "env": {
+        "MUD_HOST": "localhost",
+        "MUD_PORT": "4000",
+        "MUD_NAME": "YourCharacterName",
+        "MUD_PASSWORD": "yourpassword"
